{
  "Main function": {
    "prefix": "main",
    "body": [
      "function main()",
      "{",
      "    $1",
      "}"
    ],
    "description": "Create main function"
  },
  "Function declaration": {
    "prefix": "fun",
    "body": [
      "function ${1:name}(${2:params}): ${3:int}",
      "{",
      "    $4",
      "}"
    ],
    "description": "Create a function"
  },
  "If statement": {
    "prefix": "if",
    "body": [
      "if ${1:condition}",
      "{",
      "    $2",
      "}"
    ],
    "description": "If statement"
  },
  "If-else statement": {
    "prefix": "ifelse",
    "body": [
      "if ${1:condition}",
      "{",
      "    $2",
      "}",
      "else",
      "{",
      "    $3",
      "}"
    ],
    "description": "If-else statement"
  },
  "While loop": {
    "prefix": "while",
    "body": [
      "while ${1:condition}",
      "{",
      "    $2",
      "}"
    ],
    "description": "While loop"
  },
  "Do-while loop": {
    "prefix": "dowhile",
    "body": [
      "do",
      "{",
      "    $1",
      "}",
      "while ${2:condition}"
    ],
    "description": "Do-while loop"
  },
  "For loop": {
    "prefix": "for",
    "body": [
      "for ${1:i} = ${2:1} to ${3:10}",
      "{",
      "    $4",
      "}"
    ],
    "description": "For loop"
  },
  "Let declaration": {
    "prefix": "let",
    "body": [
      "let ${1:name}${2:: ${3:int}} = ${4:value}"
    ],
    "description": "Declare an immutable variable"
  },
  "Var declaration": {
    "prefix": "var",
    "body": [
      "var ${1:name}${2:: ${3:int}} = ${4:value}"
    ],
    "description": "Declare a mutable variable"
  },
  "Print statement": {
    "prefix": "print",
    "body": [
      "print(\"${1:text}\")"
    ],
    "description": "Print text to console"
  },
  "Input statement": {
    "prefix": "input",
    "body": [
      "let ${1:name} = input()"
    ],
    "description": "Read input from console"
  }
}
